# Qwen / DashScope API key.
# Copy this file to .env and fill in local development values.
# Supported env names:
# DASHSCOPE_API_KEY=your-api-key
# ALIYUN_ACCESS_KEY_SECRET=your-api-key
# QWEN_API_KEY=your-api-key

QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v4

SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Local default is SQLite. For MySQL, use:
# DATABASE_URL=mysql+pymysql://user:password@host:3306/contract_rag?charset=utf8mb4
DATABASE_URL=sqlite:///./data/app.db

UPLOAD_DIR=./data/uploads
CHROMA_DB_DIR=./data/vector_db
CHROMA_COLLECTION=contract_chunks
