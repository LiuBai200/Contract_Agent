# Qwen / DashScope API key.
# Copy this file to .env and fill in local development values.
# Supported env names:
# DASHSCOPE_API_KEY=your-api-key
# ALIYUN_ACCESS_KEY_SECRET=your-api-key
# QWEN_API_KEY=your-api-key

QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
RERANK_ENABLED=true
DASHSCOPE_RERANK_MODEL=qwen3-rerank
# For old GTE rerank compatibility only, set:
# DASHSCOPE_RERANK_MODEL=gte-rerank-v2
RERANK_CANDIDATE_K=20
RERANK_TIMEOUT_SECONDS=60

SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_ENABLED=true
# If Redis is unavailable, true lets requests pass in local/dev instead of breaking the API.
RATE_LIMIT_FAIL_OPEN=true
ASK_RATE_LIMIT=10
ASK_RATE_LIMIT_WINDOW_SECONDS=60
UPLOAD_RATE_LIMIT=5
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60
RAG_HITS_CACHE_ENABLED=true
RAG_HITS_CACHE_TTL_SECONDS=600
# Local default is SQLite. For MySQL, use:
# DATABASE_URL=mysql+pymysql://user:password@host:3306/contract_rag?charset=utf8mb4
DATABASE_URL=sqlite:///./data/app.db

UPLOAD_DIR=./data/uploads
CHROMA_DB_DIR=./data/vector_db
CHROMA_COLLECTION=contract_chunks
